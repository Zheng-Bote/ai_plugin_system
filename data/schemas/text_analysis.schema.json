{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Text Analysis Output",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "description": "A brief summary of the analyzed text."
    },
    "sentiment": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "enum": ["positive", "neutral", "negative"]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": ["label", "score"]
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["summary", "sentiment", "categories", "confidence"],
  "additionalProperties": false
}
