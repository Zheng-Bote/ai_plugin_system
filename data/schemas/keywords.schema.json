{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Keyword Extraction Output",
  "type": "object",
  "properties": {
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["topics", "entities", "tags", "confidence"],
  "additionalProperties": false
}
