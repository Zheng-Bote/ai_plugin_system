{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Text Normalization Output",
  "type": "object",
  "properties": {
    "normalized_text": {
      "type": "string",
      "description": "The cleaned and unified text."
    },
    "operations_performed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of normalization steps applied."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "required": ["normalized_text", "operations_performed", "confidence"],
  "additionalProperties": false
}
